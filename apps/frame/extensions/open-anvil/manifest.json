{
  "manifest_version": 3,
  "name": "Open Anvil — Agent Pilot",
  "version": "1.2.0",
  "minimum_chrome_version": "116",
  "description": "Vendor-agnostic browser automation for AI agents. MCP-compatible.",

  "permissions": [
    "tabs",
    "debugger",
    "downloads",
    "tabGroups",
    "scripting",
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "webNavigation",
    "declarativeNetRequestWithHostAccess",
    "nativeMessaging"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Open Anvil — Agent Pilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["accessibility-tree.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["ui-gate.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["ref-tools.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["distill-dom.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["dom-observer.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["event-streamer.js"],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["set-of-marks.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["quick-mode.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["agent-indicator.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["lib/*", "*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
