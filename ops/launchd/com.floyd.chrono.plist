<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/douglastalley</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>KeepAlive</key>
	<true/>
	<key>Label</key>
	<string>com.floyd.chrono</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/bin/python3</string>
		<string>/Volumes/Storage/FLOYD_WORKSTATION/ops/chrono/chrono_daemon.py</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/Users/douglastalley/Library/Logs/floyd/chrono.err.log</string>
	<key>StandardOutPath</key>
	<string>/Users/douglastalley/Library/Logs/floyd/chrono.out.log</string>
	<key>WorkingDirectory</key>
	<string>/Volumes/Storage/FLOYD_WORKSTATION/ops/chrono</string>
</dict>
</plist>
