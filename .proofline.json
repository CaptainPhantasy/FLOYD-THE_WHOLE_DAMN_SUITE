{
  "version": 1,
  "gates": [
    {
      "name": "typecheck",
      "command": [
        "npm",
        "run",
        "typecheck"
      ],
      "required": true
    },
    {
      "name": "node-syntax-frame",
      "command": [
        "node",
        "--check",
        "apps/frame/server/frame-server.mjs"
      ],
      "required": true
    }
  ],
  "include": [
    "src/**",
    "app/**",
    "lib/**",
    "cmd/**",
    "internal/**",
    "*.go",
    "*.py",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.jsx",
    "*.json",
    "*.md",
    "*.css",
    "*.html",
    "package.json",
    "package-lock.json",
    "go.mod",
    "go.sum",
    "pyproject.toml",
    "Cargo.toml",
    "Cargo.lock"
  ],
  "deny": [
    ".env",
    ".env.*",
    "*.pem",
    "*.key",
    "node_modules/**",
    ".git/**",
    ".harness/**",
    ".pi/**",
    ".omp/**",
    ".supercache/**"
  ],
  "baseBranch": "main",
  "publish": true,
  "allowLocalRemote": false,
  "allow": [
    "^apps/frame/backgrounds/"
  ]
}